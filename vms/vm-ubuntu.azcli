# Create a VM with cloud-init script to install nginx and serve a simple webpage

# Pre-requisites:
- Resource Group: SEE: identity/managed-identity.azcli
- VNet: SEE: vnet/01-vnet-create.azcli

# Variables
## RUN: login.azcli for .env variables, login and subscription selection
echo $ENV_VARS

username="pietronromano"
subnet="front-tier"
subnet_jumbbox="snet-jumpbox"
vm="${ORG}-vm-${PROJECT}-host-2"
vm_size="Standard_D2ds_v6"
cloud_init="vms/vm-ubuntu-cloud-init-nginx.txt"

# Check variables
echo "Username: $username, Subnet: $subnet, VM Name: $vm, VM Size: $vm_size"
cat $cloud_init

# Create a specific subnet if needed
az network vnet subnet create \
    --resource-group $RG \
    --vnet-name $VNET \
    --name $subnet_jumbbox \
    --address-prefixes 10.0.2.0/24

# List existing vms
az vm list --resource-group $RG -o table

# List vm images
az vm image list --output table
# List available skus (--all lists ALL skus, available or not) --size Standard_D
az vm list-skus --location $LOCATION  --output table


az vm create \
    --resource-group $RG \
    --name $vm \
    --image Ubuntu2404 \
    --size $vm_size \
    --admin-username $username \
    --generate-ssh-keys \
    --vnet-name $VNET \
    --subnet $subnet \
    --custom-data $cloud_init

az vm auto-shutdown -g $RG -n $vm --time 1800 --email "pietronromano@live.com" 

# Open ports if needed
az vm open-port --port 80 --resource-group $RG --name $vm

# Connect
ip=$(az vm show --show-details --resource-group $RG --name $vm --query publicIps --output tsv)
echo $ip

# generate-ssh keys: stores the private key in ~/.ssh/id_rsa and public key in ~/.ssh/id_rsa.pub by default, unless you specify a different path with -f. 
# If the files already exist, it will prompt you to overwrite them. You can also specify a passphrase with -N, or leave it empty for no passphrase.
## private key is here by default: /Users/macbookpro/.ssh, I also copied it to azcli folder
ssh -i ~/.ssh/id_rsa $username@$ip

# Custom host header
curl -H "Host: host1.com" $ip

# Generate SSH keys if you don't have them already (or specify a different path with -f)
ssh-keygen -t rsa -b 2048 -f id_rsa -N ""
# Use chmod to enhance security by assigning read-only access to your private key.
chmod 400 /Users/macbookpro/dev/azure/github/azure-cli/vms/id_rsa

# cloud-init logs and nginx status
sudo cloud-init status --long
sudo tail -n 200 /var/log/cloud-init-output.log
less /var/log/cloud-init-output.log
grep "nginx" /var/log/cloud-init-output.log
sudo ls -la /var/www
sudo ls -la /var/www/html
sudo systemctl status nginx --no-pager

#Also verify what custom data the VM actually has:
sudo ls -la /var/lib/cloud/instance
sudo grep -R "Host:" /var/lib/cloud -n


exit

## From inside VM, 
### curl to http site (NOTE: 502 Bad Gateway will happen if admin-username doesn't match init owner)
curl localhost

### network commands
hostname

## Note the Azure VM knows nothing of the Public IP it has associated
ifconfig

resolvectl status
nslookup vm-neu-front
# Azure has no ARP, layer 2, so this is the same in all VMs
arp-an


# NOTE for node-init! After stopping, node.js app doesn't restart automatically -> have to start manually
pietronromano@vm-eus-front:~$ cd "/home/pietronromano/myapp"
pietronromano@vm-eus-front:/home/pietronromano/myapp$ nodejs index.js
Hello world app listening on port 3000!

# Start / Stop
az vm start -g $RG -n $vm
# NOTE STOP: It will continue to be billed. To deallocate a VM, run: az vm deallocate.
az vm stop -g $RG -n $vm
az vm deallocate -g $RG -n $vm

# delete vm (NOTE: doesn't delete related resources)
az vm delete \
    --resource-group $RG \
    --name $vm \
    --force-deletion true
    --yes