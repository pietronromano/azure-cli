echo ""
echo "2. Update HTTP settings to HTTPS/443:"
echo "   az network application-gateway http-settings update --gateway-name $appgw -g $RG --name appGatewayBackendHttpSettings --protocol Https --port 443 --host-name-from-backend-pool true"
echo ""
echo "3. Check backend health:"
echo "   az network application-gateway show-backend-health --name $appgw -g $RG"

